APP_ENV=development
RACK_ENV=development
BRIDGETOWN_ENV=development

DATABASE_URL=postgres://bfp:bfp@postgres:5432/bfp_development
TEST_DATABASE_URL=postgres://bfp:bfp@localhost:5432/bfp_test
DB_POOL=5

CANONICAL_HOST=bigfluffypuffy.org

LLM_PROVIDER=bedrock
LLM_PARSE_ENABLED=false
LLM_ESCALATION_ENABLED=false
AWS_REGION=us-west-2
# Production Bedrock parser credentials are generated by infra/opentofu
# and installed on the Lightsail box by infra/ansible.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
BEDROCK_PRIMARY_MODEL_ID=global.anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_ESCALATION_MODEL_ID=global.anthropic.claude-sonnet-4-5-20250929-v1:0

CLOCK_INTERVAL_SECONDS=300
FIRE_AUTO_POLL_ENABLED=false
FIRE_POLL_BATCH_SIZE=25

# Free NPS Data API key for National Park Service alert sources.
# Register at https://www.nps.gov/subjects/developer/get-started.htm.
# NPS_API_KEY=
