{
	auto_https disable_redirects

	servers :443 {
		protocols h1 h2
	}
}

http://bigfluffypuffy.org, http://www.bigfluffypuffy.org {
	log
	redir https://bigfluffypuffy.org{uri} permanent
}

https://bigfluffypuffy.org, https://www.bigfluffypuffy.org {
	log
	header Alt-Svc "clear"
	reverse_proxy web:9292
}

http://bigfuckingpuffy.org, http://www.bigfuckingpuffy.org {
	log
	redir https://bigfluffypuffy.org{uri} permanent
}

https://bigfuckingpuffy.org, https://www.bigfuckingpuffy.org {
	log
	header Alt-Svc "clear"
	redir https://bigfluffypuffy.org{uri} permanent
}

:80 {
	log
	reverse_proxy web:9292
}
