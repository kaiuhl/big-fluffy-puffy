<% forest = detail.fetch(:forest) %>
<% source = preferred_source(forest) %>
<% checked_at = checked_at_for(forest, source) %>
<% climate_label = climate_low_column_label([forest]) %>
<% rules = detail.fetch(:localized_restrictions) %>
<% answer_statement = campfire_answer_statement(campfire_policy_for(forest)) %>
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= h(forest.fetch(:name)) %> Fire Restrictions | Big Fluffy Puffy</title>
    <meta
      name="description"
      content="Area-wide and localized camping fire-use restrictions for <%= h(forest.fetch(:name)) %>."
    >
    <link rel="stylesheet" href="/vendor/leaflet/leaflet.css">
    <link rel="stylesheet" href="<%= h(RodaApp::SITE_CSS_PATH) %>">
    <script src="/vendor/leaflet/leaflet.js" defer></script>
    <script src="<%= h(RodaApp::FIRE_RESTRICTIONS_JS_PATH) %>" defer></script>
  </head>
  <body>
    <div class="page">
      <main class="restrictions-page forest-restrictions-page">
        <%= partial("shared/site_header", current_path: "/fire-restrictions") %>

        <section class="restrictions-intro forest-restrictions-intro" aria-labelledby="forest-restrictions-title">
          <p class="kicker">Source monitor</p>
          <h1 id="forest-restrictions-title"><%= h(forest.fetch(:name)) %></h1>
          <p>
            Camping and backpacking fire-use status for this area, with localized restrictions shown only when BFP has an active published rule.
          </p>
        </section>

        <section class="restrictions-summary forest-fire-use-summary restrictions-answer-summary" aria-label="Area-wide fire use summary">
          <div class="forest-summary-layout">
            <div class="forest-summary-primary">
              <p class="summary-statement">
                <strong><%= h(answer_statement) %></strong>
              </p>
              <p class="summary-detail forest-summary-note"><%= h(restriction_note(forest)) %></p>
            </div>
            <dl class="forest-summary-grid">
              <div class="forest-summary-item">
                <dt>Status</dt>
                <dd><%= h(labelize(forest[:status])) %></dd>
              </div>
              <div class="forest-summary-item">
                <dt>Checked</dt>
                <dd>
                  <% if checked_at %>
                    <time datetime="<%= h(checked_at) %>"><%= h(date_label(checked_at)) %></time>
                  <% else %>
                    not checked
                  <% end %>
                </dd>
              </div>
              <div class="forest-summary-item forest-summary-item-source">
                <dt>Source</dt>
                <dd>
                  <% if source && source[:url] %>
                    <a href="<%= h(source[:url]) %>" rel="noreferrer"><%= h(source[:name]) %></a>
                  <% else %>
                    Not checked yet
                  <% end %>
                </dd>
              </div>
              <div class="forest-summary-item forest-summary-item-climate">
                <dt><%= h(climate_label) %></dt>
                <dd>
                  <% if climate_low_available?(forest) %>
                    <span class="climate-low-context"><%= climate_low_sparkline(forest) %></span>
                  <% else %>
                    not available
                  <% end %>
                </dd>
              </div>
            </dl>
          </div>
        </section>

        <section class="restrictions-map-section" aria-labelledby="forest-map-title">
          <div class="restrictions-map-heading">
            <div>
              <p class="summary-kicker">Map detail</p>
              <h2 id="forest-map-title"><%= h(forest.fetch(:name)) %> Map</h2>
            </div>
            <ul class="restrictions-map-legend" aria-label="Map legend">
              <li><span class="map-legend-swatch map-legend-active" aria-hidden="true"></span>Mapped active localized restriction</li>
            </ul>
          </div>
          <div
            id="restrictions-map"
            class="restrictions-map"
            data-map-endpoint="<%= h(detail.fetch(:map_endpoint)) %>"
            data-map-fit-zoom-offset="1"
            data-map-status-mode="localized-restrictions"
            data-map-total-restrictions="<%= rules.length %>"
            role="img"
            aria-label="Map of <%= h(forest.fetch(:name)) %> fire restriction areas"
          ></div>
          <p id="restrictions-map-status" class="map-status" aria-live="polite"></p>
        </section>

        <% if rules.empty? %>
          <section class="restrictions-section" aria-labelledby="localized-restrictions-title">
            <div class="restrictions-section-heading">
              <h2 id="localized-restrictions-title">Localized Restrictions</h2>
            </div>
            <div class="restrictions-table-wrap">
              <div class="empty-state empty-state-section">
                <p>No active localized camping fire-use restrictions are published by BFP for this area. Confirm with the official source before you go.</p>
              </div>
            </div>
          </section>
        <% else %>
          <% grouped_rules = [
            ["current-localized-restrictions", "Seasonal / Current Orders", rules.select { |rule| rule[:group] == "current" }, "No active current localized camping fire-use restrictions are published."],
            ["permanent-localized-restrictions", "Permanent / Standing Rules", rules.select { |rule| rule[:group] == "permanent" }, "No permanent localized camping fire-use restrictions are published."]
          ] %>
          <div class="restrictions-sections">
            <% grouped_rules.each do |id, title, section_rules, empty_message| %>
              <% noun = section_rules.length == 1 ? "rule" : "rules" %>
              <section class="restrictions-section" aria-labelledby="<%= h(id) %>">
                <div class="restrictions-section-heading">
                  <h2 id="<%= h(id) %>"><%= h(title) %></h2>
                  <p class="restrictions-section-count"><%= section_rules.length %> <%= noun %></p>
                </div>
                <div class="restrictions-table-wrap">
                  <% if section_rules.empty? %>
                    <div class="empty-state empty-state-section">
                      <p><%= h(empty_message) %></p>
                    </div>
                  <% else %>
                    <table class="restrictions-table localized-restrictions-table">
                      <thead>
                        <tr>
                          <th scope="col">Area</th>
                          <th scope="col">Fire Use</th>
                          <th scope="col">Duration</th>
                          <th scope="col">Source</th>
                        </tr>
                      </thead>
                      <tbody>
                        <% section_rules.each do |rule| %>
                          <% rule_source_url = rule[:source_url] %>
                          <% rule_source_title = rule[:source_title] || "Source" %>
                          <% fire_use = fire_use_profile(rule) %>
                          <% fire_use_chart = fire_use.render %>
                          <tr data-restriction-id="<%= h(rule[:id]) %>">
                            <th scope="row">
                              <span><%= h(rule[:title]) %></span>
                              <small><%= h(rule[:affected_area] || rule.dig(:area, :name) || "Localized area") %></small>
                            </th>
                            <td data-label="Fire Use">
                              <div class="fire-use-profile">
                                <% unless fire_use_chart.empty? %>
                                  <span class="fire-use-chart"><%= fire_use_chart %></span>
                                <% end %>
                              </div>
                            </td>
                            <td data-label="Duration"><%= h(duration_label(rule)) %></td>
                            <td data-label="Source">
                              <% if rule_source_url %>
                                <a href="<%= h(rule_source_url) %>" rel="noreferrer"><%= h(rule_source_title) %></a>
                              <% else %>
                                Not checked yet
                              <% end %>
                            </td>
                          </tr>
                        <% end %>
                      </tbody>
                    </table>
                  <% end %>
                </div>
              </section>
            <% end %>
          </div>
        <% end %>

        <%= partial("fire_restrictions/_trust") %>
      </main>
    </div>
  </body>
</html>
