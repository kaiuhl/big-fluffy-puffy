<% if wildfires && ![:none, :stale].include?(wildfires[:status]) %>
  <% status = wildfires[:status] %>
  <% minor = wildfires[:minor] %>
  <% incidents = wildfires[:incidents] || [] %>
  <% closest = incidents.first %>
  <% area_scope = wildfire_scope == :area %>
  <% place_word = area_scope ? "area" : "destination" %>
  <% headline = if minor
       case status
       when :inside
         area_scope ? "Small local fire activity is mapped inside this area." : "Small local fire activity is mapped at this location."
       else
         "Small local fire activity nearby \u2014 #{closest ? format("%.1f", closest[:distance_miles]) : "0.0"} mi from this #{place_word}."
       end
     else
       case status
       when :inside
         area_scope ? "An active wildfire is mapped inside this area." : "An active wildfire is mapped at this location."
       when :near
         "Active wildfire nearby \u2014 #{closest ? format("%.1f", closest[:distance_miles]) : "0.0"} mi from this #{place_word}."
       else
         "Active wildfire activity in the region."
       end
     end %>
  <section id="wildfire-notice" class="wildfire-callout wildfire-callout-<%= h(status) %><%= " wildfire-callout-minor" if minor %>" aria-label="Active wildfire notice">
    <p class="wildfire-callout-kicker"><%= minor ? "Local fire activity" : "Active wildfire" %></p>
    <p class="wildfire-callout-headline"><strong><%= h(headline) %></strong></p>
    <% unless incidents.empty? %>
      <table class="wildfire-incident-table">
        <thead>
          <tr>
            <th scope="col">Fire</th>
            <th scope="col">Distance</th>
            <th scope="col">Size</th>
            <th scope="col">Contained</th>
            <th scope="col" class="wildfire-cell-discovered">Discovered</th>
          </tr>
        </thead>
        <tbody>
          <% incidents.each do |incident| %>
            <% dash = "\u2014" %>
            <% distance = if incident[:distance_miles].nil?
                 dash
               elsif incident[:distance_miles] <= 0
                 "Inside"
               else
                 "#{format("%.1f", incident[:distance_miles])} mi"
               end %>
            <% size = if incident[:acres] && incident[:acres] >= 1
                 "#{incident[:acres].round.to_s.reverse.gsub(/(\d{3})(?=\d)/, "\\1,").reverse} ac"
               else
                 dash
               end %>
            <% contained = incident[:percent_contained] ? "#{incident[:percent_contained].round}%" : dash %>
            <% discovered = incident[:discovered_at] ? date_label(incident[:discovered_at]) : dash %>
            <% name = incident[:name] || "Unnamed fire" %>
            <% info_url = incident[:information_url] %>
            <% note = incident[:short_description] %>
            <tr>
              <th scope="row">
                <% if info_url %>
                  <a class="wildfire-incident-link" href="<%= h(info_url) %>" target="_blank" rel="noopener"><%= h(name) %></a>
                <% else %>
                  <%= h(name) %>
                <% end %>
                <% if note %>
                  <span class="wildfire-incident-note"><%= h(note) %></span>
                <% end %>
              </th>
              <td><%= h(distance) %></td>
              <td><%= h(size) %></td>
              <td><%= h(contained) %></td>
              <td class="wildfire-cell-discovered"><%= h(discovered) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>
    <p class="wildfire-callout-footer">
      Fire data: NIFC/WFIGS<% if wildfires[:as_of] %> &middot; as of <%= h(date_label(wildfires[:as_of])) %><% end %>
      <span class="wildfire-callout-caveat">Fire locations are planning context, not an evacuation or safety tool. Follow official emergency alerts and closures.</span>
    </p>
  </section>
<% end %>
