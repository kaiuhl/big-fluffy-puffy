<% if wildfires && ![:none, :stale].include?(wildfires[:status]) %>
  <% status = wildfires[:status] %>
  <% incidents = wildfires[:incidents] || [] %>
  <% closest = incidents.first %>
  <% area_scope = wildfire_scope == :area %>
  <% inside_label = area_scope ? "inside this area" : "mapped at this location" %>
  <% headline = case status
       when :inside
         area_scope ? "An active wildfire is mapped inside this area." : "An active wildfire is mapped at this location."
       when :near
         "Active wildfire nearby \u2014 #{closest ? format("%.1f", closest[:distance_miles]) : "0.0"} mi from this #{area_scope ? "area" : "destination"}."
       else
         "Active wildfire activity in the region."
       end %>
  <section class="wildfire-callout wildfire-callout-<%= h(status) %>" aria-label="Active wildfire notice">
    <p class="wildfire-callout-kicker">Active wildfire</p>
    <p class="wildfire-callout-headline"><strong><%= h(headline) %></strong></p>
    <% unless incidents.empty? %>
      <ul class="wildfire-incident-list">
        <% incidents.each do |incident| %>
          <% parts = [] %>
          <% if incident[:distance_miles] %>
            <% parts << ((incident[:distance_miles] <= 0) ? inside_label : "#{format("%.1f", incident[:distance_miles])} mi") %>
          <% end %>
          <% if incident[:acres] && incident[:acres] >= 1 %>
            <% acres_display = incident[:acres].round.to_s.reverse.gsub(/(\d{3})(?=\d)/, "\\1,").reverse %>
            <% parts << "#{acres_display} acres" %>
          <% end %>
          <% parts << "#{incident[:percent_contained].round}% contained" if incident[:percent_contained] %>
          <% parts << "discovered #{date_label(incident[:discovered_at])}" if incident[:discovered_at] %>
          <li class="wildfire-incident">
            <span class="wildfire-incident-name"><%= h(incident[:name] || "Unnamed fire") %></span>
            <% unless parts.empty? %>
              <span class="wildfire-incident-meta"><%= h(parts.join(" \u00b7 ")) %></span>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% end %>
    <p class="wildfire-callout-footer">
      Fire data: NIFC/WFIGS<% if wildfires[:as_of] %> &middot; as of <%= h(date_label(wildfires[:as_of])) %><% end %>
    </p>
    <p class="wildfire-callout-caveat">Fire locations are planning context, not an evacuation or safety tool. Follow official emergency alerts and closures.</p>
  </section>
<% end %>
