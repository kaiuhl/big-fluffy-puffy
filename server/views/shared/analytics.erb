<% measurement_id = google_analytics_measurement_id %>
<% if measurement_id %>
    <script async src="https://www.googletagmanager.com/gtag/js?id=<%= h(measurement_id) %>"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag("js", new Date());
      gtag("config", "<%= h(measurement_id) %>");
    </script>
<% end %>
