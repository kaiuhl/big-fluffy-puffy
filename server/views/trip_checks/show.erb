<% place = check.fetch(:place) %>
<% verdict = check.fetch(:verdict) %>
<% primary_forest = check[:primary_forest] %>
<% source = primary_forest ? preferred_source(primary_forest) : nil %>
<% checked_at = primary_forest ? checked_at_for(primary_forest, source) : nil %>
<% climate_label = primary_forest ? climate_low_column_label([primary_forest]) : "Typical lows" %>
<% matched_rules = check.fetch(:localized_restrictions) %>
<% forest_rules = check.fetch(:forest_localized_restrictions, []) %>
<% matched_rule_source = matched_rules.find { |rule| rule[:source_url] } %>
<% answer_source_url = matched_rule_source ? matched_rule_source[:source_url] : source&.fetch(:url, nil) %>
<% answer_source_name = matched_rule_source ? (matched_rule_source[:source_title] || matched_rule_source[:title]) : source&.fetch(:name, nil) %>
<% answer_statement = campfire_answer_statement(check.fetch(:campfire_policy), allowed_text: "No BFP campfire restriction matched.") %>
<% location_parts = [] %>
<% location_parts << "#{place[:county_name]} County" if place[:county_name].to_s != "" %>
<% location_parts << "#{place[:map_name]} USGS quad" if place[:map_name].to_s != "" %>
<% forest_rules_url = primary_forest ? "#{primary_forest[:forest_url]}#current-localized-restrictions" : nil %>
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= h(place.fetch(:name)) %> Trip Check | Big Fluffy Puffy</title>
    <meta
      name="description"
      content="Source-linked fire-use trip check for <%= h(place.fetch(:name)) %>."
    >
    <link rel="stylesheet" href="/vendor/leaflet/leaflet.css">
    <link rel="stylesheet" href="<%= h(RodaApp::SITE_CSS_PATH) %>">
    <script src="/vendor/leaflet/leaflet.js" defer></script>
    <script src="<%= h(RodaApp::FIRE_RESTRICTIONS_JS_PATH) %>" defer></script>
    <%= partial("shared/analytics") %>
  </head>
  <body>
    <div class="page">
      <main class="restrictions-page trip-check-page">
        <%= partial("shared/site_header", current_path: "/fire-restrictions") %>

        <section class="restrictions-intro trip-check-intro" aria-labelledby="trip-check-title">
          <p class="kicker">Trip check</p>
          <h1 id="trip-check-title"><%= h(place.fetch(:name)) %></h1>
          <% if primary_forest %>
            <p class="trip-check-forest-line">
              In <a href="<%= h(primary_forest[:forest_url]) %>"><%= h(primary_forest[:name]) %></a>
            </p>
          <% end %>
          <% unless location_parts.empty? %>
            <p class="trip-check-location-line"><%= h(location_parts.join(" / ")) %></p>
          <% end %>
        </section>

        <section class="restrictions-summary forest-fire-use-summary restrictions-answer-summary trip-check-destination-summary trip-check-verdict-<%= h(verdict.fetch(:tone)) %>" aria-label="Trip check answer">
          <div class="forest-summary-layout">
            <div class="forest-summary-primary">
              <p class="summary-statement trip-check-answer-statement">
                <strong><%= h(answer_statement) %></strong>
              </p>
              <p class="summary-detail forest-summary-note"><%= h(verdict.fetch(:detail)) %></p>
            </div>
            <dl class="forest-summary-grid">
              <% if primary_forest %>
                <div class="forest-summary-item">
                  <dt>Area-wide campfires</dt>
                  <dd><%= h(labelize(campfire_policy_for(primary_forest))) %></dd>
                </div>
              <% end %>
              <div class="forest-summary-item">
                <dt>Localized match</dt>
                <dd><%= h(matched_rules.length) %> <%= matched_rules.length == 1 ? "rule" : "rules" %></dd>
              </div>
              <div class="forest-summary-item">
                <dt>Checked</dt>
                <dd>
                  <% if checked_at %>
                    <time datetime="<%= h(checked_at) %>"><%= h(date_label(checked_at)) %></time>
                  <% else %>
                    not checked
                  <% end %>
                </dd>
              </div>
              <div class="forest-summary-item forest-summary-item-source">
                <dt>Source</dt>
                <dd>
                  <% if answer_source_url %>
                    <a href="<%= h(answer_source_url) %>" rel="noreferrer"><%= h(answer_source_name || "Source") %></a>
                  <% else %>
                    Not checked yet
                  <% end %>
                </dd>
              </div>
              <% if primary_forest %>
                <div class="forest-summary-item forest-summary-item-climate">
                  <dt><%= h(climate_label) %></dt>
                  <dd>
                    <% if climate_low_available?(primary_forest) %>
                      <span class="climate-low-context"><%= climate_low_sparkline(primary_forest) %></span>
                    <% else %>
                      not available
                    <% end %>
                  </dd>
                </div>
              <% end %>
            </dl>
          </div>
        </section>

        <section class="restrictions-map-section" aria-labelledby="trip-map-title">
          <div class="restrictions-map-heading">
            <div>
              <p class="summary-kicker">Map detail</p>
              <h2 id="trip-map-title">
                <% if primary_forest %>
                  <%= h(primary_forest.fetch(:name)) %> Map
                <% else %>
                  <%= h(place.fetch(:name)) %> Map
                <% end %>
              </h2>
            </div>
            <ul class="restrictions-map-legend" aria-label="Map legend">
              <li><span class="map-legend-swatch map-legend-active" aria-hidden="true"></span>Mapped active localized restriction</li>
              <li><span class="map-legend-swatch map-legend-destination" aria-hidden="true"></span>Trip Location</li>
            </ul>
          </div>
          <div
            id="restrictions-map"
            class="restrictions-map"
            data-map-endpoint="/api/trip-check/<%= h(place.fetch(:slug)) %>/map"
            data-map-fit-zoom-offset="1"
            data-map-focus-lat="<%= h(place[:latitude]) %>"
            data-map-focus-lon="<%= h(place[:longitude]) %>"
            data-map-focus-zoom="10"
            data-map-status-mode="localized-restrictions"
            data-map-total-restrictions="<%= check.fetch(:map).fetch(:localized_rule_count) %>"
            role="img"
            aria-label="Map of <%= h(place.fetch(:name)) %> trip check context"
          ></div>
          <p id="restrictions-map-status" class="map-status" aria-live="polite"></p>
        </section>

        <section class="restrictions-section" aria-labelledby="trip-local-rules-title">
          <div class="restrictions-section-heading">
            <h2 id="trip-local-rules-title">Localized Rules At This Waypoint</h2>
            <p class="restrictions-section-count"><%= h(matched_rules.length) %> matched</p>
          </div>
          <div class="restrictions-table-wrap">
            <% if matched_rules.empty? %>
              <div class="empty-state empty-state-section">
                <p>No active localized camping fire-use rule is matched to this exact waypoint.</p>
              </div>
            <% else %>
              <table class="restrictions-table localized-restrictions-table">
                <thead>
                  <tr>
                    <th scope="col">Area</th>
                    <th scope="col">Fire Use</th>
                    <th scope="col">Duration</th>
                    <th scope="col">Source</th>
                  </tr>
                </thead>
                <tbody>
                  <% matched_rules.each do |rule| %>
                    <% fire_use = fire_use_profile(rule) %>
                    <tr>
                      <th scope="row">
                        <span><%= h(rule[:title]) %></span>
                        <small><%= h(rule[:affected_area] || "Localized area") %></small>
                      </th>
                      <td data-label="Fire Use">
                        <div class="fire-use-profile">
                          <span class="fire-use-chart"><%= fire_use.render %></span>
                        </div>
                      </td>
                      <td data-label="Duration"><%= h(duration_label(rule)) %></td>
                      <td data-label="Source">
                        <% if rule[:source_url] %>
                          <a href="<%= h(rule[:source_url]) %>" rel="noreferrer"><%= h(rule[:source_title] || "Source") %></a>
                        <% else %>
                          Not checked yet
                        <% end %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            <% end %>
            <% if forest_rules_url %>
              <p class="trip-check-forest-link">
                <a href="<%= h(forest_rules_url) %>">See all localized rules in <%= h(primary_forest[:name]) %></a>
                <span><%= h(forest_rules.length) %> total</span>
              </p>
            <% end %>
          </div>
        </section>

        <section class="restrictions-trust" aria-labelledby="trip-check-trust-title">
          <p class="summary-kicker">How to read this</p>
          <h2 id="trip-check-trust-title">Source-linked, not official</h2>
          <div class="restrictions-trust-grid">
            <p>Place matches are planning context, not surveyed legal boundaries.</p>
            <p>Approximate BFP shapes help identify relevant areas; official sources and posted signs control.</p>
            <p>Unknown means BFP has not published a claim yet. It does not mean campfires are allowed.</p>
          </div>
        </section>

        <% unless check.fetch(:datasets).empty? %>
          <section class="trip-check-attribution" aria-label="Place data attribution">
            <% check.fetch(:datasets).each do |dataset| %>
              <p>
                Place data: <%= h(dataset[:attribution_text] || dataset[:name]) %>
                <% if dataset[:license_url] %>
                  <a href="<%= h(dataset[:license_url]) %>" rel="noreferrer"><%= h(dataset[:license_name]) %></a>
                <% else %>
                  <%= h(dataset[:license_name]) %>
                <% end %>
              </p>
            <% end %>
          </section>
        <% end %>
      </main>
    </div>
  </body>
</html>
